rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Chat images: any authenticated user can read/write
    match /chat_images/{chatRoomId}/{fileName} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
