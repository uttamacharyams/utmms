{
  "name": "memorial-chat-system/api",
  "description": "Memorial Admin Chat System REST API with Firebase Integration",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Your Name",
      "email": "your.email@example.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "firebase/php-jwt": "^6.10",
    "kreait/firebase-php": "^7.8",
    "guzzlehttp/guzzle": "^7.8",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.5",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-openssl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "MemorialChat\\": "src/"
    },
    "files": [
      "config/database.php",
      "config/firebase.php",
      "utils/Response.php",
      "utils/JWT.php",
      "utils/Validator.php",
      "utils/FirebaseService.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "MemorialChat\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "start": "php -S localhost:8000 -t public",
    "seed": "php scripts/seed.php",
    "migrate": "php scripts/migrate.php"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/kreait/firebase-php.git"
    }
  ]
}
